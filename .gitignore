# ------------------------------
# Environment and secrets
# ------------------------------
.env
.env.*
!.env.example

# ------------------------------
# Python virtual environments
# ------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------
# Python bytecode and caches
# ------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Test and analysis caches
# ------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/

# ------------------------------
# Coverage and test outputs
# ------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/

# ------------------------------
# Build and packaging artifacts
# ------------------------------
build/
dist/
site/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# ------------------------------
# Notebook artifacts
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# Logs and temporary files
# ------------------------------
*.log
*.out
*.tmp
*.temp
.cache/

# ------------------------------
# IDE and editor settings
# ------------------------------
.vscode/
.idea/
*.iml

# ------------------------------
# OS files
# ------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------
# Python version managers
# ------------------------------
.python-version

# ------------------------------
# Project runtime data outputs
# ------------------------------
data/pdf/
data/metadata/
data/extracted/
data/reports/

# Keep structure and examples if needed
!data/.gitkeep
!data/**/.gitkeep

# ------------------------------
# Archives and backups
# ------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ------------------------------
# Postman local exports (optional)
# ------------------------------
